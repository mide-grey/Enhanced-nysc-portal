# ─────────────────────────────────────────────────────────────
#  NYSC AI Portal  –  Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Django core
SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
GEMINI_API_KEY= AIzaSyDoxGZwUSOY1_yx-02HAFXy2IHoHGtcL1A

# Database (SQLite default – no change needed for dev)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# JWT settings (seconds)
JWT_ACCESS_TOKEN_LIFETIME=3600
JWT_REFRESH_TOKEN_LIFETIME=86400

# OpenAI (chatbot)
OPENAI_API_KEY=sk-your-openai-key-here

# Email (development: console backend)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# Media / Static
MEDIA_URL=/media/
STATIC_URL=/static/
